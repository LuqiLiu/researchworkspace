{
	email {$CADDY_EMAIL:off}
	admin off
}

{$DOMAIN:localhost} {
	encode zstd gzip

	handle_path /static/* {
		root * /srv/static
		file_server
		header Cache-Control "public, max-age=31536000, immutable"
	}

	handle {
		reverse_proxy web:8000
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}

	log {
		output stdout
		format console
	}
}
