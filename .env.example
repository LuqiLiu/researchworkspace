# Docker Compose
COMPOSE_PROJECT_NAME=research_workspace
DOMAIN=localhost

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost,http://localhost
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
CROSSREF_MAILTO=
CROSSREF_TIMEOUT_SECONDS=4

# PostgreSQL
POSTGRES_DB=research_workspace
POSTGRES_USER=research_workspace
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Application server
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=30
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
MIGRATE_ON_STARTUP=true

# 2-core / 2-GB host guardrails
DB_MEMORY_LIMIT=512m
DB_CPU_LIMIT=0.65
WEB_MEMORY_LIMIT=768m
WEB_CPU_LIMIT=1.0
CADDY_MEMORY_LIMIT=128m
CADDY_CPU_LIMIT=0.35
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
MINIMUM_FREE_DISK_MB=1024

# Initial administrator (used by `python manage.py init_admin`)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-admin-password
