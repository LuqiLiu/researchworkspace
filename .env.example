# Docker Compose
COMPOSE_PROJECT_NAME=research_workspace
DOMAIN=localhost

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost,http://localhost
DJANGO_LOG_LEVEL=INFO
DJANGO_SECURE_SSL_REDIRECT=false
CROSSREF_MAILTO=
CROSSREF_TIMEOUT_SECONDS=4

# PostgreSQL
POSTGRES_DB=research_workspace
POSTGRES_USER=research_workspace
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# Application server
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=30
MIGRATE_ON_STARTUP=true

# Initial administrator (used by `python manage.py init_admin`)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-admin-password
